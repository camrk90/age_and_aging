res <- map_dfr(beta_thresholds, function(x) {
df <- age_trunc %>%
filter(between(beta_eq3_age_m, -x, x))
test <- tidy(cor.test(df$beta_chron_age, df$beta_eq2_w_age))
test$threshold <- x
test
})
View(res)
